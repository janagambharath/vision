generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ProductStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum InventoryStatus {
  IN_STOCK
  LOW_STOCK
  OUT_OF_STOCK
  PRICE_REQUIRED
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PACKED
  SHIPPED
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
  REFUNDED
  TRY_AT_HOME_BOOKED
  AWAITING_PRESCRIPTION
  LENS_IN_PROCESSING
}

enum PaymentStatus {
  PENDING
  AUTHORIZED
  PAID
  FAILED
  REFUNDED
}

enum PaymentMethod {
  RAZORPAY
  UPI
  CARD
  NETBANKING
  COD
  WHATSAPP_ASSISTED
}

enum DeliveryMethod {
  DELIVERY
  TRY_AT_HOME
  STORE_PICKUP
}

enum LeadStatus {
  NEW
  CONTACTED
  TRY_ON_DONE
  HOME_TRIAL_BOOKED
  FRAME_SELECTED
  PAYMENT_PENDING
  BOOKED
  DELIVERED
  CONVERTED
}

enum AdminRole {
  OWNER
  MANAGER
  STAFF
}

enum PreviewStatus {
  RECEIVED
  PROCESSING
  READY
  FALLBACK_READY
  FAILED
}

model User {
  id             String            @id @default(cuid())
  name           String?
  email          String?           @unique
  phone          String?           @unique
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  deletedAt      DateTime?
  carts          Cart[]
  orders         Order[]
  wishlistItems  WishlistItem[]
  reviews        Review[]
  prescriptions  Prescription[]
  shipping       ShippingAddress[]

  @@index([phone])
  @@index([createdAt])
}

model AdminUser {
  id           String        @id @default(cuid())
  email        String        @unique
  name         String
  passwordHash String
  role         AdminRole     @default(STAFF)
  active       Boolean       @default(true)
  failedLogins Int           @default(0)
  lockedUntil  DateTime?
  lastLoginAt  DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  activityLogs ActivityLog[]
}

// ─── BRAND ───
model Brand {
  id             String    @id @default(cuid())
  slug           String    @unique
  name           String
  logoUrl        String?
  bannerUrl      String?
  description    String?
  seoTitle       String?
  seoDescription String?
  active         Boolean   @default(true)
  sortOrder      Int       @default(0)
  products       Product[]
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([active])
}

// ─── CATEGORY (supports nesting) ───
model Category {
  id             String            @id @default(cuid())
  slug           String            @unique
  name           String
  description    String?
  imageUrl       String?
  bannerUrl      String?
  seoTitle       String?
  seoDescription String?
  featured       Boolean           @default(false)
  parentId       String?
  parent         Category?         @relation("CategoryTree", fields: [parentId], references: [id])
  children       Category[]        @relation("CategoryTree")
  sortOrder      Int               @default(0)
  products       ProductCategory[]
  banners        Banner[]
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@index([parentId])
  @@index([featured])
}

// ─── COLLECTION ───
model Collection {
  id          String              @id @default(cuid())
  slug        String              @unique
  name        String
  description String?
  imageUrl    String?
  active      Boolean             @default(true)
  sortOrder   Int                 @default(0)
  products    ProductCollection[]
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
}

// ─── TAG ───
model Tag {
  id        String       @id @default(cuid())
  slug      String       @unique
  name      String
  products  ProductTag[]
  createdAt DateTime     @default(now())
}

// ─── PRODUCT ───
model Product {
  id                    String              @id @default(cuid())
  slug                  String              @unique
  sku                   String              @unique
  barcode               String?
  name                  String
  // Legacy string brand field kept for backward compat; new products should use brandId
  brand                 String
  brandId               String?
  brandRef              Brand?              @relation(fields: [brandId], references: [id])
  status                ProductStatus       @default(DRAFT)
  featured              Boolean             @default(false)

  // Pricing
  pricePaise            Int?
  compareAtPaise        Int?
  costPricePaise        Int?
  taxPct                Int?                @default(18)
  currency              String              @default("INR")
  codAvailable          Boolean             @default(true)

  // Descriptions
  shortDescription      String?
  description           String
  highlights            String[]
  careInstructions      String?
  warranty              String?
  returnPolicy          String?
  deliveryEstimate      String?

  // Classification
  gender                String?             // "Men", "Women", "Unisex", "Kids"
  ageGroup              String?             // "Adult", "Kids", "Teen"

  // Frame details
  material              String?
  colour                String?
  finish                String?
  shape                 String?
  rimType               String?
  size                  String?
  measurements          String?
  weightGrams           Int?

  // Frame specifications
  frameWidth            Int?
  lensWidth             Int?
  bridgeWidth           Int?
  templeLength          Int?
  frameHeight           Int?
  pdRange               String?
  springHinges          Boolean             @default(false)
  blueLightCompatible   Boolean             @default(false)
  prescriptionCompatible Boolean            @default(true)
  lensCompatibility     String[]
  faceShapes            String[]

  // Flags
  tryAtHomeEligible     Boolean             @default(false)
  tryOnEligible         Boolean             @default(false)
  arImageUrl            String?
  whatsappEnabled       Boolean             @default(true)

  // SEO
  seoTitle              String?
  seoDescription        String?
  seoKeywords           String[]

  // Publishing
  publishedAt           DateTime?
  scheduledPublishAt    DateTime?

  // Search
  searchText            String              @default("")
  supplierSku           String?

  // Timestamps
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  deletedAt             DateTime?

  // Relations
  images                ProductImage[]
  categories            ProductCategory[]
  collections           ProductCollection[]
  tags                  ProductTag[]
  inventory             Inventory?
  cartItems             CartItem[]
  orderItems            OrderItem[]
  reviews               Review[]
  wishlistItems         WishlistItem[]
  previewRequests       FramePreviewRequest[]
  imageUploads       ProductImageUpload[]

  @@index([status])
  @@index([brand])
  @@index([brandId])
  @@index([searchText])
  @@index([createdAt])
  @@index([featured])
  @@index([gender])
  @@index([deletedAt])
  @@index([publishedAt])
}

model ProductCategory {
  productId  String
  categoryId String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([productId, categoryId])
}

model ProductCollection {
  productId    String
  collectionId String
  product      Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  collection   Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)

  @@id([productId, collectionId])
}

model ProductTag {
  productId String
  tagId     String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  tag       Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([productId, tagId])
}

model ProductImage {
  id        String   @id @default(cuid())
  productId String
  url       String
  alt       String
  role      String   @default("gallery")
  sortOrder Int      @default(0)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([productId, role])
}

model ProductImageUpload {
  id          String    @id @default(cuid())
  productId   String?
  fileName    String
  status      String    @default("uploading")
  assetUrl    String?
  errorReason String?
  attempt     Int       @default(0)
  lastAttempt DateTime?
  product     Product?  @relation(fields: [productId], references: [id], onDelete: SetNull)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([productId])
  @@index([status])
  @@index([createdAt])
}

model Inventory {
  id                String          @id @default(cuid())
  productId         String          @unique
  quantity          Int             @default(0)
  reservedStock     Int             @default(0)
  lowStockThreshold Int             @default(2)
  reorderLevel      Int             @default(5)
  status            InventoryStatus @default(PRICE_REQUIRED)
  supplier          String?
  supplierSku       String?
  warehouse         String?
  location          String?
  product           Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  updatedAt         DateTime        @updatedAt
}

model LensOption {
  id          String     @id @default(cuid())
  code        String     @unique
  name        String
  description String
  pricePaise  Int?
  active      Boolean    @default(false)
  sortOrder   Int        @default(0)
  cartItems   CartItem[]
  orderItems  OrderItem[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Cart {
  id        String     @id @default(cuid())
  sessionId String     @unique
  userId    String?
  user      User?      @relation(fields: [userId], references: [id])
  items     CartItem[]
  couponId  String?
  coupon    Coupon?    @relation(fields: [couponId], references: [id])
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([updatedAt])
}

model CartItem {
  id             String         @id @default(cuid())
  cartId         String
  productId      String
  lensOptionId   String?
  quantity       Int            @default(1)
  deliveryMethod DeliveryMethod @default(DELIVERY)
  tryAtHome      Boolean        @default(false)
  savedForLater  Boolean        @default(false)
  cart           Cart           @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product        Product        @relation(fields: [productId], references: [id])
  lensOption     LensOption?    @relation(fields: [lensOptionId], references: [id])
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([cartId])
}

model Order {
  id                String            @id @default(cuid())
  publicId          String            @unique
  userId            String?
  user              User?             @relation(fields: [userId], references: [id])
  customerName      String
  phone             String
  email             String?
  status            OrderStatus       @default(PENDING)
  deliveryMethod    DeliveryMethod    @default(DELIVERY)
  paymentMethod     PaymentMethod     @default(RAZORPAY)
  subtotalPaise     Int
  lensTotalPaise    Int               @default(0)
  shippingPaise     Int               @default(0)
  taxPaise          Int               @default(0)
  discountPaise     Int               @default(0)
  grandTotalPaise   Int
  notes             String?
  prescriptionNote  String?
  couponCode        String?
  items             OrderItem[]
  payments          Payment[]
  shippingAddress   ShippingAddress?
  tryAtHomeRequest  TryAtHomeRequest?
  prescriptions     Prescription[]
  notifications     Notification[]
  refunds           Refund[]
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@index([status])
  @@index([phone])
  @@index([createdAt])
}

model OrderItem {
  id              String      @id @default(cuid())
  orderId         String
  productId       String?
  lensOptionId    String?
  quantity        Int
  unitPricePaise  Int
  lensPricePaise  Int         @default(0)
  productSnapshot Json
  lensSnapshot    Json?
  order           Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product         Product?    @relation(fields: [productId], references: [id])
  lensOption      LensOption? @relation(fields: [lensOptionId], references: [id])
}

model Payment {
  id                String        @id @default(cuid())
  orderId           String
  provider          String        @default("razorpay")
  providerOrderId   String?
  providerPaymentId String?
  signature         String?
  status            PaymentStatus @default(PENDING)
  amountPaise       Int
  rawPayload        Json?
  order             Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@index([providerOrderId])
  @@index([providerPaymentId])
  @@index([status])
}

model PaymentWebhookEvent {
  id              String   @id @default(cuid())
  provider        String   @default("razorpay")
  providerEventId String   @unique
  eventType       String
  paymentId       String?
  orderId         String?
  processed       Boolean  @default(false)
  payload         Json
  createdAt       DateTime @default(now())

  @@index([provider, eventType])
  @@index([paymentId])
  @@index([orderId])
  @@map("payment_webhook_events")
}

model ShippingAddress {
  id        String   @id @default(cuid())
  userId    String?
  orderId   String?  @unique
  name      String
  phone     String
  line1     String
  line2     String?
  city      String
  state     String?
  pincode   String
  country   String   @default("India")
  user      User?    @relation(fields: [userId], references: [id])
  order     Order?   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TryAtHomeRequest {
  id              String      @id @default(cuid())
  orderId         String?     @unique
  name            String
  phone           String
  address         String
  preferredDate   DateTime
  preferredSlot   String
  frameCount      Int
  depositPaise    Int         @default(0)
  serviceFeePaise Int         @default(19900)
  status          OrderStatus @default(TRY_AT_HOME_BOOKED)
  productIds      String[]
  notes           String?
  order           Order?      @relation(fields: [orderId], references: [id])
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([phone])
  @@index([status])
  @@index([preferredDate])
}

model Prescription {
  id          String   @id @default(cuid())
  userId      String?
  orderId     String?
  fileUrl     String
  fileName    String?
  notes       String?
  verified    Boolean  @default(false)
  user        User?    @relation(fields: [userId], references: [id])
  order       Order?   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
}

model Coupon {
  id             String   @id @default(cuid())
  code           String   @unique
  description    String?
  active         Boolean  @default(false)
  discountPaise  Int?
  discountPct    Int?
  minOrderPaise  Int?
  maxUses        Int?
  usedCount      Int      @default(0)
  expiresAt      DateTime?
  carts          Cart[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Review {
  id        String   @id @default(cuid())
  productId String
  userId    String?
  name      String?
  rating    Int
  title     String?
  body      String
  imageUrls String[]
  verified  Boolean  @default(false)
  approved  Boolean  @default(false)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user      User?    @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())

  @@index([productId, approved])
}

model WishlistItem {
  id        String   @id @default(cuid())
  userId    String?
  sessionId String?
  productId String
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, productId])
  @@unique([sessionId, productId])
  @@index([sessionId])
}

model FramePreviewRequest {
  id               String        @id @default(cuid())
  productId        String
  productSlug      String
  customerImageUrl String
  frameImageUrl    String?
  resultImageUrl   String?
  status           PreviewStatus @default(RECEIVED)
  disclaimer       String
  promptVersion    String
  prompt           String
  failureReason    String?
  product          Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@index([productSlug])
  @@index([status])
  @@index([createdAt])
  @@map("frame_preview_requests")
}

model Lead {
  id        String     @id @default(cuid())
  name      String
  phone     String
  email     String?
  source    String
  status    LeadStatus @default(NEW)
  intent    String?
  payload   Json?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([status])
  @@index([phone])
  @@index([source])
  @@index([createdAt])
}

model HomepageSection {
  id        String   @id @default(cuid())
  key       String   @unique
  title     String
  body      String?
  active    Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Banner {
  id         String    @id @default(cuid())
  title      String
  subtitle   String?
  imageUrl   String?
  href       String?
  active     Boolean   @default(false)
  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id])
  startsAt   DateTime?
  endsAt     DateTime?
  sortOrder  Int       @default(0)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}

model ActivityLog {
  id          String     @id @default(cuid())
  adminUserId String?
  action      String
  entityType  String
  entityId    String?
  metadata    Json?
  adminUser   AdminUser? @relation(fields: [adminUserId], references: [id])
  createdAt   DateTime   @default(now())

  @@index([entityType, entityId])
  @@index([createdAt])
}

model Notification {
  id        String   @id @default(cuid())
  orderId   String?
  channel   String
  recipient String
  subject   String?
  body      String?
  status    String   @default("pending")
  entityType String?
  entityId   String?
  metadata   Json?
  sentAt    DateTime?
  error     String?
  order     Order?   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orderId])
  @@index([channel, status])
  @@index([entityType, entityId])
  @@index([createdAt])
}

model AnalyticsEvent {
  id         String   @id @default(cuid())
  event      String
  sessionId  String?
  userId     String?
  productId  String?
  orderId    String?
  source     String?
  path       String?
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([event])
  @@index([sessionId])
  @@index([createdAt])
}

// Customer OTP for phone-based auth
model OtpCode {
  id        String   @id @default(cuid())
  phone     String
  code      String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([phone])
  @@index([expiresAt])
}

// Guest wishlist (for when we have no account system, store by session)
model GuestWishlist {
  id        String   @id @default(cuid())
  sessionId String   @unique
  slugs     String[]
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

// Refund records
model Refund {
  id                  String   @id @default(cuid())
  orderId             String
  paymentId           String
  providerRefundId    String?
  amountPaise         Int
  reason              String
  initiatedByAdminId  String?
  status              String   @default("pending")
  order               Order    @relation(fields: [orderId], references: [id])
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([orderId])
}

// ─── SLUG REDIRECT (301 redirects for changed slugs) ───
model SlugRedirect {
  id        String   @id @default(cuid())
  oldSlug   String   @unique
  newSlug   String
  createdAt DateTime @default(now())

  @@index([oldSlug])
}

// ─── SEARCH LOG (for autocomplete and trending searches) ───
model SearchLog {
  id          String   @id @default(cuid())
  query       String
  resultCount Int      @default(0)
  sessionId   String?
  createdAt   DateTime @default(now())

  @@index([query])
  @@index([createdAt])
}


