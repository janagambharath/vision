generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ProductStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum InventoryStatus {
  IN_STOCK
  LOW_STOCK
  OUT_OF_STOCK
  PRICE_REQUIRED
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PACKED
  SHIPPED
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
  REFUNDED
  TRY_AT_HOME_BOOKED
  AWAITING_PRESCRIPTION
  LENS_IN_PROCESSING
}

enum PaymentStatus {
  PENDING
  AUTHORIZED
  PAID
  FAILED
  REFUNDED
}

enum PaymentMethod {
  RAZORPAY
  UPI
  CARD
  NETBANKING
  COD
  WHATSAPP_ASSISTED
}

enum DeliveryMethod {
  DELIVERY
  TRY_AT_HOME
  STORE_PICKUP
}

enum LeadStatus {
  NEW
  CONTACTED
  TRY_ON_DONE
  HOME_TRIAL_BOOKED
  FRAME_SELECTED
  PAYMENT_PENDING
  BOOKED
  DELIVERED
  CONVERTED
}

enum AdminRole {
  OWNER
  MANAGER
  STAFF
}

model User {
  id             String            @id @default(cuid())
  name           String?
  email          String?           @unique
  phone          String?           @unique
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  deletedAt      DateTime?
  carts          Cart[]
  orders         Order[]
  wishlistItems  WishlistItem[]
  reviews        Review[]
  prescriptions  Prescription[]
  shipping       ShippingAddress[]

  @@index([createdAt])
}

model AdminUser {
  id           String        @id @default(cuid())
  email        String        @unique
  name         String
  passwordHash String
  role         AdminRole     @default(STAFF)
  active       Boolean       @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  activityLogs ActivityLog[]
}

model Category {
  id          String            @id @default(cuid())
  slug        String            @unique
  name        String
  description String?
  imageUrl    String?
  sortOrder   Int               @default(0)
  products    ProductCategory[]
  banners     Banner[]
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
}

model Product {
  id                 String            @id @default(cuid())
  slug               String            @unique
  sku                String            @unique
  name               String
  brand              String
  status             ProductStatus     @default(DRAFT)
  featured           Boolean           @default(false)
  pricePaise         Int?
  compareAtPaise     Int?
  currency           String            @default("INR")
  description        String
  material           String?
  colour             String?
  shape              String?
  rimType            String?
  size               String?
  measurements       String?
  lensCompatibility  String[]
  faceShapes         String[]
  highlights         String[]
  careInstructions   String?
  warranty           String?
  returnPolicy       String?
  deliveryEstimate   String?
  tryAtHomeEligible  Boolean           @default(false)
  whatsappEnabled    Boolean           @default(true)
  seoTitle           String?
  seoDescription     String?
  searchText         String            @default("")
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  deletedAt          DateTime?
  images             ProductImage[]
  categories         ProductCategory[]
  inventory          Inventory?
  cartItems          CartItem[]
  orderItems         OrderItem[]
  reviews            Review[]
  wishlistItems      WishlistItem[]

  @@index([status])
  @@index([brand])
  @@index([createdAt])
  @@index([featured])
}

model ProductCategory {
  productId  String
  categoryId String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([productId, categoryId])
}

model ProductImage {
  id        String   @id @default(cuid())
  productId String
  url       String
  alt       String
  role      String   @default("gallery")
  sortOrder Int      @default(0)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([productId])
}

model Inventory {
  id                String          @id @default(cuid())
  productId         String          @unique
  quantity          Int             @default(0)
  lowStockThreshold Int             @default(2)
  status            InventoryStatus @default(PRICE_REQUIRED)
  supplier          String?
  location          String?
  product           Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  updatedAt         DateTime        @updatedAt
}

model LensOption {
  id          String     @id @default(cuid())
  code        String     @unique
  name        String
  description String
  pricePaise  Int?
  active      Boolean    @default(false)
  sortOrder   Int        @default(0)
  cartItems   CartItem[]
  orderItems  OrderItem[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Cart {
  id        String     @id @default(cuid())
  sessionId String     @unique
  userId    String?
  user      User?      @relation(fields: [userId], references: [id])
  items     CartItem[]
  couponId  String?
  coupon    Coupon?    @relation(fields: [couponId], references: [id])
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([updatedAt])
}

model CartItem {
  id             String         @id @default(cuid())
  cartId         String
  productId      String
  lensOptionId   String?
  quantity       Int            @default(1)
  deliveryMethod DeliveryMethod @default(DELIVERY)
  tryAtHome      Boolean        @default(false)
  savedForLater  Boolean        @default(false)
  cart           Cart           @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product        Product        @relation(fields: [productId], references: [id])
  lensOption     LensOption?    @relation(fields: [lensOptionId], references: [id])
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([cartId])
}

model Order {
  id                String            @id @default(cuid())
  publicId          String            @unique
  userId            String?
  user              User?             @relation(fields: [userId], references: [id])
  customerName      String
  phone             String
  email             String?
  status            OrderStatus       @default(PENDING)
  deliveryMethod    DeliveryMethod    @default(DELIVERY)
  paymentMethod     PaymentMethod     @default(RAZORPAY)
  subtotalPaise     Int
  lensTotalPaise    Int               @default(0)
  shippingPaise     Int               @default(0)
  taxPaise          Int               @default(0)
  discountPaise     Int               @default(0)
  grandTotalPaise   Int
  notes             String?
  prescriptionNote  String?
  couponCode        String?
  items             OrderItem[]
  payments          Payment[]
  shippingAddress   ShippingAddress?
  tryAtHomeRequest  TryAtHomeRequest?
  prescriptions     Prescription[]
  notifications     Notification[]
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@index([status])
  @@index([phone])
  @@index([createdAt])
}

model OrderItem {
  id              String      @id @default(cuid())
  orderId         String
  productId       String?
  lensOptionId    String?
  quantity        Int
  unitPricePaise  Int
  lensPricePaise  Int         @default(0)
  productSnapshot Json
  lensSnapshot    Json?
  order           Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product         Product?    @relation(fields: [productId], references: [id])
  lensOption      LensOption? @relation(fields: [lensOptionId], references: [id])
}

model Payment {
  id                String        @id @default(cuid())
  orderId           String
  provider          String        @default("razorpay")
  providerOrderId   String?
  providerPaymentId String?
  signature         String?
  status            PaymentStatus @default(PENDING)
  amountPaise       Int
  rawPayload        Json?
  order             Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@index([providerOrderId])
}

model ShippingAddress {
  id        String   @id @default(cuid())
  userId    String?
  orderId   String?  @unique
  name      String
  phone     String
  line1     String
  line2     String?
  city      String
  state     String?
  pincode   String
  country   String   @default("India")
  user      User?    @relation(fields: [userId], references: [id])
  order     Order?   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TryAtHomeRequest {
  id              String      @id @default(cuid())
  orderId         String?     @unique
  name            String
  phone           String
  address         String
  preferredDate   DateTime
  preferredSlot   String
  frameCount      Int
  depositPaise    Int         @default(0)
  serviceFeePaise Int         @default(19900)
  status          OrderStatus @default(TRY_AT_HOME_BOOKED)
  productIds      String[]
  notes           String?
  order           Order?      @relation(fields: [orderId], references: [id])
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([phone])
  @@index([status])
}

model Prescription {
  id          String   @id @default(cuid())
  userId      String?
  orderId     String?
  fileUrl     String
  fileName    String?
  notes       String?
  verified    Boolean  @default(false)
  user        User?    @relation(fields: [userId], references: [id])
  order       Order?   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
}

model Coupon {
  id             String   @id @default(cuid())
  code           String   @unique
  description    String?
  active         Boolean  @default(false)
  discountPaise  Int?
  discountPct    Int?
  minOrderPaise  Int?
  maxUses        Int?
  usedCount      Int      @default(0)
  expiresAt      DateTime?
  carts          Cart[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Review {
  id        String   @id @default(cuid())
  productId String
  userId    String?
  name      String?
  rating    Int
  title     String?
  body      String
  approved  Boolean  @default(false)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user      User?    @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())

  @@index([productId, approved])
}

model WishlistItem {
  id        String   @id @default(cuid())
  userId    String
  productId String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, productId])
}

model Lead {
  id        String     @id @default(cuid())
  name      String
  phone     String
  email     String?
  source    String
  status    LeadStatus @default(NEW)
  intent    String?
  payload   Json?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([status])
  @@index([phone])
  @@index([createdAt])
}

model HomepageSection {
  id        String   @id @default(cuid())
  key       String   @unique
  title     String
  body      String?
  active    Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Banner {
  id         String    @id @default(cuid())
  title      String
  subtitle   String?
  imageUrl   String?
  href       String?
  active     Boolean   @default(false)
  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id])
  startsAt   DateTime?
  endsAt     DateTime?
  sortOrder  Int       @default(0)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}

model ActivityLog {
  id          String     @id @default(cuid())
  adminUserId String?
  action      String
  entityType  String
  entityId    String?
  metadata    Json?
  adminUser   AdminUser? @relation(fields: [adminUserId], references: [id])
  createdAt   DateTime   @default(now())

  @@index([entityType, entityId])
  @@index([createdAt])
}

model Notification {
  id        String   @id @default(cuid())
  orderId   String?
  channel   String
  recipient String
  subject   String?
  body      String?
  status    String   @default("pending")
  sentAt    DateTime?
  error     String?
  order     Order?   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([orderId])
  @@index([channel, status])
}

model AnalyticsEvent {
  id         String   @id @default(cuid())
  event      String
  sessionId  String?
  userId     String?
  productId  String?
  orderId    String?
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([event])
  @@index([createdAt])
}
